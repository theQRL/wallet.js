{
  "name": "@theqrl/wallet.js",
  "version": "3.0.0",
  "description": "Quantum-resistant wallet library for The QRL using ML-DSA-87 (FIPS 204)",
  "type": "module",
  "main": "dist/cjs/wallet.js",
  "module": "dist/mjs/wallet.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/mjs/wallet.js",
      "require": "./dist/cjs/wallet.js"
    }
  },
  "scripts": {
    "build": "rollup -c && ./fixup && tsc",
    "prepublishOnly": "npm run build",
    "test": "mocha",
    "test:browser": "playwright test",
    "lint-check": "eslint 'src/**/*.js' 'test/**/*.js'",
    "lint": "eslint --fix 'src/**/*.js' 'test/**/*.js'",
    "report-coverage": "c8 --reporter=text-lcov npm run test > coverage.lcov",
    "coverage": "c8 npm run test"
  },
  "author": "QRL contributors <info@theqrl.org> (https://theqrl.org)",
  "license": "MIT",
  "engines": {
    "node": ">=20.19"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/theQRL/wallet.js"
  },
  "dependencies": {
    "@noble/hashes": "2.0.1",
    "@theqrl/mldsa87": "2.0.1"
  },
  "directories": {
    "lib": "src",
    "test": "test"
  },
  "c8": {
    "include": [
      "src/**/*.js"
    ],
    "exclude": [
      "scripts/**",
      "dist/**",
      "test/**",
      "browser-tests/**"
    ],
    "all": true,
    "src": [
      "src"
    ]
  },
  "files": [
    "dist",
    "src",
    "types"
  ],
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.58.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@types/node": "25.5.0",
    "c8": "11.0.0",
    "chai": "6.2.2",
    "conventional-changelog-conventionalcommits": "9.3.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-prettier": "5.5.5",
    "fast-check": "4.6.0",
    "globals": "17.4.0",
    "mocha": "11.7.5",
    "playwright": "1.58.2",
    "prettier": "3.8.1",
    "rollup": "4.59.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "eslint-plugin-import-x": {
      "eslint": "$eslint"
    },
    "serialize-javascript": "7.0.3",
    "minimatch": "10.2.4",
    "glob": "13.0.6",
    "tar": "7.5.11",
    "diff": "8.0.3",
    "npm": {
      ".": "11.11.1",
      "minimatch": "10.2.4"
    }
  }
}
